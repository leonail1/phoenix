[global]
ioengine=external:__ENGINE__
name=__JOB_NAME__
filename=__FILENAME__
size=__SIZE__
runtime=__RUNTIME__
time_based=1
ramp_time=5
group_reporting=1
direct=1
rw=randread
bs=4k
numjobs=1
norandommap=1
randrepeat=0
iodepth=__IODEPTH__
iodepth_batch_submit=__IODEPTH__
iodepth_batch_complete_min=__IODEPTH__
iodepth_batch_complete_max=__IODEPTH__
device_id=__DEVICE_ID__
enable_phoenix=__ENABLE_PHOENIX__
enable_iouring=1

